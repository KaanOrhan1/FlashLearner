# FlashLearn Environment Variables
# 
# This file contains secrets and should NEVER be committed to git.
# It's already in .gitignore.

# Firebase Configuration (public, safe to share)
# These are already in src/lib/firebase.js
REACT_APP_FIREBASE_ENABLED=true

# ============================================
# AI Generation Setup
# ============================================
# 
# Option 1: Production with Deployed Cloud Function (RECOMMENDED)
# 
# After deploying your Cloud Functions, get the function URL:
#   firebase functions:list
# 
# Then update this:
REACT_APP_GENERATE_FLASHCARDS_URL=https://us-central1-flashlearn-49cc8.cloudfunctions.net/generateFlashcards

# 
# Option 2: Local Development with Firebase Emulator
# 
# To use the local Firebase emulator instead of production:
# (Comment out REACT_APP_GENERATE_FLASHCARDS_URL above first)
# 
# REACT_APP_FIREBASE_FUNCTIONS_EMULATOR=http://localhost:5001/flashlearn-49cc8/us-central1/generateFlashcards

# ============================================
# Notes
# ============================================
# 
# 1. The OpenAI API key is NOT stored here.
#    It's set securely in Cloud Functions:
#      firebase functions:config:set openai.api_key="sk-..."
# 
# 2. Never put your OpenAI API key in this file.
#    If you do, it will be exposed in browser bundles.
# 
# 3. Never commit this file to git (it's in .gitignore).
# 
# 4. After changing REACT_APP_GENERATE_FLASHCARDS_URL,
#    restart your React dev server: npm start
